@model List<Restoran_masa_ve_adisyon_yönetimi_sistemi.Models.Masa>

@{
    ViewData["Title"] = "Masa Yönetimi";
}

<div class="container mt-5">
    
    <div class="row mb-4 align-items-center">
        <div class="col-md-8 text-center text-md-start">
            <h2 class="text-white fw-bold">🪑 Masa Yerleşim Planı</h2>
            <p class="text-secondary">Restoranınızdaki tüm masaların durumunu buradan izleyebilirsiniz.</p>
        </div>
        <div class="col-md-4 text-center text-md-end">
            <button type="button" class="btn btn-warning btn-lg shadow rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#masaEkleModal">
                <i class="me-1">+</i> Yeni Masa Ekle
            </button>
        </div>
    </div>

    <div class="card bg-dark border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 text-center align-middle">
                <thead class="table-secondary text-dark">
                    <tr>
                        <th class="py-3">Masa Numarası / Adı</th>
                        <th class="py-3">Anlık Durum</th>
                        <th class="py-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="py-5 text-muted fst-italic">Henüz bir masa tanımlanmamış.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var masa in Model)
                        {
                            <tr class="border-bottom border-secondary border-opacity-10">
                                <td class="fw-bold fs-5 text-info">@masa.MasaNo</td>
                                <td>
                                    @if (masa.DoluMu)
                                    {
                                        <span class="badge bg-danger bg-opacity-75 rounded-pill px-3 py-2 border border-danger">🔴 Dolu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-75 rounded-pill px-3 py-2 border border-success">🟢 Boş</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Masa/Detay/@masa.Id" class="btn btn-outline-light btn-sm rounded-pill px-4 shadow-sm">
                                        Detay / Adisyon ➔
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="masaEkleModal" tabindex="-1" aria-labelledby="modalBaslik" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary shadow-lg rounded-4">
            
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title text-white fw-bold" id="modalBaslik">✨ Yeni Masa Tanımla</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>

            <form action="/Masa/Ekle" method="post">
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label text-warning small fw-bold text-uppercase">Masa İsmi veya Numarası</label>
                        <input type="text" name="MasaNo" class="form-control form-control-lg bg-black border-secondary text-white shadow-sm"
                               placeholder="Örn: Salon 4, VIP 2 veya Masa 12" required />
                    </div>
                    
                    <div class="alert alert-info bg-info bg-opacity-10 border-info border-opacity-25 text-info small mb-0">
                        <i class="me-2">ℹ️</i> Yeni eklenen masalar sistem tarafından otomatik olarak <b>"Boş"</b> (🟢) olarak işaretlenir.
                    </div>
                </div>

                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal Et</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold">Masayı Kaydet</button>
                </div>
            </form>
            
        </div>
    </div>
</div>
<style>
    /* Tablo satırı üzerine gelince hafif neon parlaması */
    .table-hover tbody tr:hover {
        background-color: rgba(13, 202, 240, 0.05) !important;
        transition: 0.3s;
    }
    
    /* Input odaklanınca sarı çerçeve */
    .form-control:focus {
        background-color: #000;
        border-color: #ffc107;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
        color: white;
    }
</style>