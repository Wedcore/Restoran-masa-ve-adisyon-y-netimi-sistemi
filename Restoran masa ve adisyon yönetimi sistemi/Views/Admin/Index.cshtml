@{
    ViewData["Title"] = "Patron Paneli";
}

<div class="container mt-5 text-center">
    <h1 class="text-warning display-4 fw-bold mb-5" style="text-shadow: 2px 2px 4px #000;">👑 Patron Komuta Merkezi</h1>
    
    <div class="row justify-content-center mt-5">
        
        <div class="col-md-4 mb-4">
            <a href="/Admin/Rezervasyonlar" class="card bg-dark text-white border-warning shadow-lg text-decoration-none h-100 dev-buton">
                <div class="card-body py-5">
                    <h1 style="font-size: 5rem;">🛎️</h1>
                    <h2 class="fw-bold mt-3 text-warning">Talepler</h2>
                    <p class="text-muted fs-5 mt-2">Gelen masa rezervasyonlarını onayla veya reddet.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4 mb-4">
            <a href="/Admin/Adisyon" class="card bg-dark text-white border-info shadow-lg text-decoration-none h-100 dev-buton">
                <div class="card-body py-5">
                    <h1 style="font-size: 5rem;">📝</h1>
                    <h2 class="fw-bold mt-3 text-info">Adisyon</h2>
                    <p class="text-muted fs-5 mt-2">Masalara sipariş gir, hesap al ve masaları yönet.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4 mb-4">
            <a href="/Admin/Ciro" class="card bg-dark text-white border-success shadow-lg text-decoration-none h-100 dev-buton">
                <div class="card-body py-5">
                    <h1 style="font-size: 5rem;">💰</h1>
                    <h2 class="fw-bold mt-3 text-success">Kasa & Ciro</h2>
                    <p class="text-muted fs-5 mt-2">Gün sonu satış raporlarını ve toplam hasılatı gör.</p>
                </div>
            </a>
        </div>

    </div>
</div>

<style>
    body {

        background-color: #121212;
    }
    .dev-buton {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 20px;
        border-width: 2px;
    }

        .dev-buton:hover {
            transform: translateY(-15px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
        }
</style>