@model List<Restoran_masa_ve_adisyon_yönetimi_sistemi.Models.Satis>

<div class="container mt-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="text-white fw-bold">💰 Kasa ve Satış Geçmişi</h2>
            <p class="text-secondary fst-italic">İşletmenizin tüm finansal dökümü ve geçmiş tahsilatlar.</p>
        </div>
        <div class="col-md-4">
            <div class="card bg-success bg-gradient text-white shadow-lg border-0 rounded-4 p-3 text-center">
                <h6 class="text-uppercase fw-bold opacity-75 small mb-1">Toplam Ciro</h6>
                <h2 class="fw-bold mb-0">@ViewBag.ToplamCiro ₺</h2>
            </div>
        </div>
    </div>

    <div class="card bg-dark border-secondary border-opacity-25 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 text-center align-middle">
                <thead class="table-secondary text-dark">
                    <tr>
                        <th class="py-3">Masa Bilgisi</th>
                        <th class="py-3">İşlem Tarihi</th>
                        <th class="py-3">Tahsil Edilen Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="py-5 text-muted">
                                <i class="fs-1 d-block mb-2">📥</i>
                                Henüz bir satış kaydı bulunmuyor.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var satis in Model)
                        {
                            <tr class="border-bottom border-secondary border-opacity-10">
                                <td class="fw-bold fs-5">Masa @satis.MasaId</td>
                                <td class="text-secondary">@satis.SatisTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-success fw-bold fs-5">@satis.ToplamTutar ₺</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Tablo satırlarına hafif geçiş efekti */
    .table-hover tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.03) !important;
        transition: 0.2s;
    }
</style>