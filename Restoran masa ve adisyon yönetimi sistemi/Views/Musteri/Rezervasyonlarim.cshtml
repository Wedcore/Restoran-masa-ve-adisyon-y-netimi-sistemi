@model IEnumerable<Restoran_masa_ve_adisyon_yönetimi_sistemi.Models.Rezervasyon>

@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="container mt-5">
    <h2 class="text-white mb-4">📋 Senin Rezervasyonların</h2>

    <div class="card bg-dark text-white shadow" style="border-radius: 15px;">
        <div class="card-body">
            <table class="table table-dark table-hover align-middle text-center">
                <thead>
                    <tr class="text-info">
                        <th>Müşteri Adı</th>
                        <th>Masa No</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-muted py-4">Henüz bir rezervasyonun bulunmuyor.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var rez in Model)
                        {
                            <tr>
                                <td class="fw-bold">@rez.MusteriAdi</td>
                                <td class="fw-bold fs-5 text-warning">Masa @rez.MasaId</td>
                                <td>@rez.Tarih.ToString("dd MMMM yyyy - HH:mm")</td>
                                <td>
                                    @* 🚀 KRİTİK DÜZELTME: Nesne (Durum) yerine ID (DurumId) karşılaştırıyoruz *@
                                    @if (rez.DurumId == 1)
                                    {
                                        <span class="badge bg-warning text-dark p-2" style="font-size: 14px;">⏳ Beklemede</span>
                                    }
                                    else if (rez.DurumId == 2)
                                    {
                                        <span class="badge bg-success p-2" style="font-size: 14px;">✅ Onaylandı</span>
                                    }
                                    else if (rez.DurumId == 3)
                                    {
                                        <span class="badge bg-danger p-2" style="font-size: 14px;">❌ Reddedildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary p-2" style="font-size: 14px;">❓ Belirsiz</span>
                                    }
                                </td>
                                <td>
                                    @if (rez.DurumId == 1)
                                    {
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="/Musteri/Guncelle/@rez.Id" class="btn btn-sm btn-outline-primary rounded-pill fw-bold">📅 Güncelle</a>
                                            
                                            <form action="/Musteri/RezervasyonSil" method="post" onsubmit="return confirm('Rezervasyonunuzu iptal etmek istediğinize emin misiniz?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@rez.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill fw-bold">❌ İptal</button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">İşlem Kapalı</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            
            <div class="text-center mt-4">
                <a href="/Rezervasyon/Index" class="btn btn-info w-100 fw-bold rounded-pill p-2">Yeni Rezervasyon Yap</a>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: #121212;
    }
</style>